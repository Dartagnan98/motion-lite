# Copy this to .env.local and fill in your own values.
# Nothing here is required to BOOT the app, but the AI features need the
# Anthropic key, and email-based meeting transcript ingest needs IMAP creds.

# --- Required for AI meeting notes + dispatch ---
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# --- Optional: meeting transcript ingest via email ---
# When meetings end, your meeting bot (Otter/Fireflies/Plaud/etc) emails the
# transcript. The IMAP poller pulls those emails and processes them into
# meeting-notes + auto-creates tasks via Anthropic.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your.email@gmail.com
IMAP_PASSWORD=your-app-password
IMAP_FOLDER=INBOX

# --- Optional: web push notifications ---
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@example.com

# --- Optional: outbound email (notifications) ---
# Either configure SendGrid (preferred) OR SMTP. SendGrid can also be set
# via Settings UI → CRM → SendGrid API key (no restart needed).
SENDGRID_API_KEY=

# Or use SMTP instead of SendGrid:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM="Motion Lite <noreply@example.com>"

# --- Optional: Meta (Facebook) Ads integration ---
# Get from https://developers.facebook.com → Create App → Business → grab App ID + Secret
# Add ads_management + ads_read + read_insights scopes
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:4000/api/auth/facebook/callback

# --- Optional: Google OAuth (Gmail / Calendar / Sheets) ---
# Get from https://console.cloud.google.com → OAuth 2.0 Client IDs (Web)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# --- Optional: Google Ads ---
# Same Google OAuth client as above, plus a developer token from Google Ads
# (Tools → API Center → request developer token, takes ~24-48h to approve).
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# Reuses GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET above for OAuth.
GOOGLE_ADS_REDIRECT_URI=http://localhost:4000/api/auth/google-ads/callback

# --- Optional: Zoom (for cloud meeting transcripts) ---
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URI=http://localhost:4000/api/auth/zoom/callback

# --- Optional: dispatch bridge to a local Mac ---
# If you want dispatch tasks to forward to a Claude Code instance on your
# Mac (the "bridge" pattern), set the bridge endpoint + shared secret.
# See README → Dispatch section for the full architecture.
BRIDGE_ENDPOINT=http://localhost:17992
BRIDGE_SECRET=change-me-shared-secret

# --- Auth ---
# Cookie session secret. Generate any 32+ char random string.
AUTH_SECRET=replace-with-32-char-random-string

# --- DB path (defaults to ../store/motion.db relative to cwd) ---
# DB_PATH=
